// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum SaleStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// 1. Nuevo enum para los estados de pago
enum TransactionStatus {
  pending
  approved
  rejected
}

model User {
  id                Int       @id @default(autoincrement())
  createdAt         DateTime  @default(now())
  email             String    @unique @db.VarChar(100)
  password          String    @db.VarChar(255)
  name              String    @db.VarChar(50)

  // Campos para la recuperación de contraseña
  resetToken        String?   @unique @db.VarChar(255)
  resetTokenExpires DateTime?

  @@map("user")
}

model Client {
  id                Int       @id @default(autoincrement())
  name              String    @db.VarChar(50)
  surname           String    @db.VarChar(50)
  dni               String    @unique @db.VarChar(8)
  phoneNumber       String    @map("phone_number") @db.VarChar(20)
  email             String    @db.VarChar(100)

  sales             Sale[]
  addresses         BillAddress[]

  // 2. Relación con las transacciones
  transactions      Transaction[]

  @@map("client_info")
}

model BillAddress {
  id                Int       @id @default(autoincrement())
  street            String    @db.VarChar(100)
  streetNum         Int       @map("street_num")
  floor             Int?
  apartment         String?   @db.VarChar(10)
  locality          String    @db.VarChar(100)
  province          String    @db.VarChar(100)
  postalCode        String    @map("postal_code") @db.VarChar(20)
  country           String    @db.VarChar(100)
  reference         String?   @db.VarChar(255)

  clientId          Int       @map("client_id")
  client            Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sales             Sale[]

  @@map("bill_address")
}

model Category {
  id                Int           @id @default(autoincrement())
  name              String        @unique @map("category_name") @db.VarChar(100)
  createdAt         DateTime      @default(now()) @map("created_at")
  status            Boolean       @default(true)
  subCategories     SubCategory[]

  @@map("categories")
}

model SubCategory {
  id                Int       @id @default(autoincrement())
  name              String    @unique @map("subcategory_name") @db.VarChar(100)
  createdAt         DateTime  @default(now()) @map("created_at")
  status            Boolean   @default(true)

  categoryId        Int       @map("categories_id")
  category          Category  @relation(fields: [categoryId], references: [id])

  products          Product[]

  @@map("subcategories")
}

model Brand {
  id                Int       @id @default(autoincrement())
  name              String    @unique @map("marca_name") @db.VarChar(100)
  createdAt         DateTime  @default(now()) @map("created_at")
  status            Boolean   @default(true)

  products          Product[]

  @@map("brand")
}

model Sale {
  id                Int           @id @default(autoincrement())
  createdAt         DateTime      @default(now()) @map("created_at")
  status            SaleStatus    @default(PENDING)
  total             Decimal       @db.Decimal(10, 2)
  isStockDeducted   Boolean       @default(false) @map("is_stock_deducted")
  expiresAt         DateTime?     @map("expires_at")

  clientId          Int           @map("client_id")
  client            Client        @relation(fields: [clientId], references: [id])
  addressId         Int?          @map("address_id")
  address           BillAddress?  @relation(fields: [addressId], references: [id])
  details           SaleDetails[]
  transaction       Transaction?

  @@map("sale")
}

model SaleDetails {
  id                Int       @id @default(autoincrement())

  saleId            Int       @map("sale_id")
  productId         Int       @map("product_id")

  quantity          Int
  unitaryPrice      Decimal   @map("unitary_price")

  sale              Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product           Product   @relation(fields: [productId], references: [id])

  @@unique([saleId, productId])
  @@map("sale_details")
}

model Transaction {
  id                Int               @id @default(autoincrement())
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  amount            Decimal           @db.Decimal(10, 2)
  status            TransactionStatus @default(pending)

  // ID que devuelve Mercado Pago
  mpId              String?           @unique @map("mp_id") @db.VarChar(255)

  // Información del método de pago
  paymentMethod     String?           @map("payment_method") @db.VarChar(50)
  paymentType       String?           @map("payment_type") @db.VarChar(50)
  cardLastFour      String?           @map("card_last_four") @db.VarChar(4)

  // Relación con Sale (1 a 1)
  saleId            Int               @unique @map("sale_id")
  sale              Sale              @relation(fields: [saleId], references: [id], onDelete: Cascade)

  // Relación con Client
  clientId          Int               @map("client_id")
  client            Client            @relation(fields: [clientId], references: [id])

  @@map("transactions")
}

model Product {
  id                Int           @id @default(autoincrement())
  name              String        @db.VarChar(100)
  description       String        @db.VarChar(500)
  unit              String        @db.VarChar(50)
  price             Decimal       @db.Decimal(12, 2)
  status            Boolean       @default(true)
  createdAt         DateTime      @default(now()) @map("created_at")
  imageUrl          String        @map("img") @db.VarChar(255)
  stock             Int
  showingInCatalog  Boolean       @default(false) @map("showing_in_catalog")

  subCategoryId     Int           @map("sub_categories_id")
  subCategory       SubCategory   @relation(fields: [subCategoryId], references: [id])

  brandId           Int           @map("brand_id")
  brand             Brand         @relation(fields: [brandId], references: [id])

  saleDetails       SaleDetails[]

  @@map("products")
}
